{
  "name": "mal-search-system",
  "version": "5.0.0",
  "description": "MAL - My Agent Locator: 47都道府県・7サイト横断不動産情報統合検索システム",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev --compatibility-date=2024-09-23 --d1=MAL_DB --kv=MAL_CACHE",
    "build": "tsc && vite build",
    "deploy": "wrangler pages deploy dist",
    "db:migrate": "wrangler d1 migrations apply MAL_DB",
    "db:seed": "wrangler d1 execute MAL_DB --file=./migrations/seed.sql",
    "type-check": "tsc --noEmit",
    "test": "tsx tests/scrapers/suumo.test.ts"
  },
  "dependencies": {
    "hono": "^4.6.3",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "playwright": "^1.44.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^3.78.0"
  }
}
