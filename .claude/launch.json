{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "MAL Dev Server (Wrangler Pages)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8788
    },
    {
      "name": "MAL Build",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "port": 0
    },
    {
      "name": "MAL DB Migrate",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:migrate"],
      "port": 0
    },
    {
      "name": "MAL DB Seed",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "db:seed"],
      "port": 0
    },
    {
      "name": "MAL Deploy (Cloudflare Pages)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "deploy"],
      "port": 0
    }
  ]
}
