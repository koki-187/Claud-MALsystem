{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit'; then cd /home/user/Claud-MALsystem && bash scripts/auto-push.sh; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/Claud-MALsystem && bash scripts/health-check.sh 2>&1 || true"
          }
        ]
      }
    ]
  }
}
